SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Cloud Translation API Key (for dynamic translation of any phrase/language)
# Get your API key: https://console.cloud.google.com → APIs & Services → Enable "Cloud Translation API"
# If NOT set, the app falls back to the free (unofficial) Google Translate endpoint automatically.
GOOGLE_TRANSLATE_API_KEY=your-google-cloud-api-key-here
