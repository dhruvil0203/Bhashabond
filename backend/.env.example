# Supabase credentials (for translation history sync — optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Cloud Translation API Key (for dynamic translation of any phrase/language)
# Get your API key: https://console.cloud.google.com → APIs & Services → Enable "Cloud Translation API"
# If NOT set, the app falls back to the free (unofficial) Google Translate endpoint automatically.
# Recommended: Set this key for reliable production translations.
GOOGLE_TRANSLATE_API_KEY=

# Google Gemini API Key (for free AI-powered translation of all Indian languages)
# Get your free key: https://aistudio.google.com/apikey (no billing account needed)
# Free tier: 60 requests/min, 1,500 requests/day
GEMINI_API_KEY=
