# Clerk authentication — get this from https://dashboard.clerk.com
# Project → API Keys → Publishable key (starts with pk_test_ or pk_live_)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Backend API URL (production Render deployment)
# Get this from your Render dashboard after deployment
EXPO_PUBLIC_API_URL=https://bhashabond-api.onrender.com

# For local development on a physical device:
# 1. Find your machine's local IP (e.g., 192.168.1.5)
# 2. Uncomment and set the line below with your IP
# 3. Restart Expo for the change to take effect
# 4. Run the backend: cd backend && uvicorn main:app --host 0.0.0.0 --port 8000
# EXPO_PUBLIC_API_URL=http://192.168.1.5:8000
