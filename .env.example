# Clerk authentication — get this from https://dashboard.clerk.com
# Project → API Keys → Publishable key (starts with pk_test_ or pk_live_)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Backend API URL (Render deployment)
# Get this from your Render dashboard after deployment
# Format: https://your-app-name.onrender.com
EXPO_PUBLIC_API_URL=https://bhashabond-api.onrender.com
