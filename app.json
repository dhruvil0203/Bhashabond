{
  "expo": {
    "owner": "dhruvil0203",
    "name": "BhashaBond",
    "slug": "BhashaBond",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "bhashabond",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "BhashaBond needs microphone access for voice-to-text translation.",
        "NSSpeechRecognitionUsageDescription": "BhashaBond uses speech recognition for translating your voice."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "RECORD_AUDIO"
      ],
      "package": "com.dhruvil0203.BhashaBond"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "263d5152-d7f1-4c03-b26d-304d3900d0f2"
      }
    }
  }
}
